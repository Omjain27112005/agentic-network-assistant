# =============================================
# Agentic Network Assistant — Environment Config
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git — only .env.example

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_METRICS=network.metrics
KAFKA_TOPIC_ALERTS=network.alerts
KAFKA_TOPIC_ACTIONS=network.actions
KAFKA_TOPIC_INCIDENTS=network.incidents

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL_METRICS=60        # seconds — live metric cache expiry
REDIS_TTL_ALERTS=3600       # seconds — alert cache expiry

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=network_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/network_assistant

# --- Groq LLM ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192   # Fast + smart — best for agentic tasks

# --- Jira ---
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_PROJECT_KEY=NET           # Jira project key for network incidents

# --- FastAPI Gateway ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true                # Set to false in production
CORS_ORIGINS=http://localhost:5173   # React dev server

# --- Network Simulator ---
SIMULATOR_INTERVAL_SECONDS=5   # How often to generate metrics
SIMULATOR_DEVICE_COUNT=10
ANOMALY_INJECTION_RATE=0.05    # 5% chance of anomaly per cycle

# --- Logging ---
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                # json | text
